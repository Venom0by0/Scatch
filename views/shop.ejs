<%- include('./partials/header') %>

    <main class="min-h-screen pt-24 pb-12 px-4 sm:px-6 lg:px-10 transition-colors duration-300">
        <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-8 lg:gap-10">
            <aside class="lg:w-64 shrink-0">
                <div class="bg-white dark:bg-zinc-900 rounded-2xl shadow-soft border border-zinc-100 dark:border-zinc-800 p-6 sticky top-24 transition-colors duration-300">
                    <h3 class="text-xs font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500 mb-4">Browse</h3>
                    <nav class="flex flex-col gap-1 mb-8">
                        <a class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-brand-50 dark:hover:bg-brand-500/10 hover:text-brand-600 dark:hover:text-brand-400 transition-colors" href="/shop">
                            <i class="ri-fire-line"></i> New Collection
                        </a>
                        <a class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium bg-brand-50 dark:bg-brand-500/20 text-brand-700 dark:text-brand-300" href="/shop">
                            <i class="ri-grid-line"></i> All Products
                        </a>
                        <a class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-brand-50 dark:hover:bg-brand-500/10 hover:text-brand-600 dark:hover:text-brand-400 transition-colors" href="/shop">
                            <i class="ri-price-tag-3-line"></i> Discounted
                        </a>
                    </nav>

                    <h3 class="text-xs font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500 mb-4">Sort by</h3>
                    <form action="/shop">
                        <select class="w-full px-3 py-2.5 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-xl text-sm text-zinc-900 dark:text-zinc-100 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500" name="sortby">
                            <option value="popular">Popular</option>
                            <option value="newest">Newest</option>
                        </select>
                    </form>

                    <h3 class="text-xs font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500 mb-4 mt-8">Filter</h3>
                    <nav class="flex flex-col gap-1">
                        <a class="px-3 py-2 text-sm text-zinc-600 dark:text-zinc-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors" href="">Availability</a>
                        <a class="px-3 py-2 text-sm text-zinc-600 dark:text-zinc-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors" href="">Discount</a>
                    </nav>
                </div>
            </aside>

            <section class="flex-1">
                <div class="mb-8">
                    <h1 class="text-3xl font-bold text-zinc-900 dark:text-white">Shop Collection</h1>
                    <p class="text-zinc-500 dark:text-zinc-400 mt-1">Handpicked products just for you</p>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
                    <% if(products && products.length > 0){ %>
                        <% products.forEach(function(product){ %>
                            <article class="group bg-white dark:bg-zinc-900 rounded-2xl overflow-hidden shadow-soft border border-zinc-100 dark:border-zinc-800 hover:shadow-card hover:-translate-y-1 transition-all duration-300">
                                <div class="w-full h-56 flex items-center justify-center bg-[<%= product.bgcolor %>] overflow-hidden">
                                    <% if(product.image){ %>
                                        <img class="h-48 object-contain group-hover:scale-105 transition-transform duration-300"
                                            src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                                            alt="<%= product.name %>">
                                    <% } %>
                                </div>
                                <div class="flex justify-between items-center px-5 py-4 bg-[<%= product.panelcolor %>] text-[<%= product.textcolor %>]">
                                    <div>
                                        <h3 class="font-semibold text-base"><%= product.name %></h3>
                                        <p class="text-sm opacity-90 mt-0.5">₹ <%= product.price %></p>
                                        <% if(product.discount > 0){ %>
                                            <span class="inline-block mt-1 text-xs font-medium px-2 py-0.5 rounded-full bg-white/20"><%= product.discount %>% off</span>
                                        <% } %>
                                    </div>
                                    <a class="w-10 h-10 flex items-center justify-center rounded-full bg-white text-zinc-800 shadow-md hover:scale-110 hover:shadow-lg transition-all" href="" title="Add to cart">
                                        <i class="ri-add-line text-lg"></i>
                                    </a>
                                </div>
                            </article>
                        <% }) %>
                    <% } else { %>
                        <div class="col-span-full flex flex-col items-center justify-center py-20 px-6 bg-white dark:bg-zinc-900 rounded-2xl border border-dashed border-zinc-200 dark:border-zinc-700 transition-colors duration-300">
                            <span class="w-16 h-16 rounded-2xl bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-400 dark:text-zinc-500 mb-4">
                                <i class="ri-shopping-bag-line text-3xl"></i>
                            </span>
                            <h3 class="text-lg font-semibold text-zinc-700 dark:text-zinc-300">No products yet</h3>
                            <p class="text-zinc-500 dark:text-zinc-400 text-sm mt-1 text-center">Check back soon — new items are on the way.</p>
                        </div>
                    <% } %>
                </div>
            </section>
        </div>
    </main>

    <%- include('./partials/footer') %>
