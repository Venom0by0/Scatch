<%- include('./partials/header') %>

    <main class="min-h-screen pt-24 pb-12 px-4 sm:px-6 lg:px-10 transition-colors duration-300">
        <div class="max-w-6xl mx-auto">
            <div class="mb-8">
                <h1 class="text-3xl font-bold text-zinc-900 dark:text-white">Your Cart</h1>
                <p class="text-zinc-500 dark:text-zinc-400 mt-1">Review items before checkout</p>
            </div>

            <div class="grid lg:grid-cols-5 gap-8">
                <div class="lg:col-span-2">
                    <div class="bg-white dark:bg-zinc-900 rounded-2xl shadow-soft border border-zinc-100 dark:border-zinc-800 overflow-hidden transition-colors duration-300">
                        <div class="w-full h-64 bg-gradient-to-br from-amber-400 to-yellow-500 flex items-center justify-center">
                            <i class="ri-shopping-bag-3-fill text-6xl text-white/40"></i>
                        </div>
                        <div class="p-5">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <h3 class="text-xl font-bold text-zinc-900 dark:text-white">Clinge Bag</h3>
                                    <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-0.5">Premium collection</p>
                                </div>
                                <div class="flex items-center gap-2 bg-zinc-100 dark:bg-zinc-800 rounded-xl p-1">
                                    <button type="button" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white dark:bg-zinc-700 shadow-sm hover:bg-zinc-50 dark:hover:bg-zinc-600 transition-colors text-zinc-800 dark:text-zinc-100">
                                        <i class="ri-subtract-line text-sm"></i>
                                    </button>
                                    <span class="w-8 text-center text-sm font-semibold text-zinc-900 dark:text-white">01</span>
                                    <button type="button" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white dark:bg-zinc-700 shadow-sm hover:bg-zinc-50 dark:hover:bg-zinc-600 transition-colors text-zinc-800 dark:text-zinc-100">
                                        <i class="ri-add-line text-sm"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="flex items-center justify-between pt-4 border-t border-zinc-100 dark:border-zinc-800">
                                <span class="text-sm font-medium text-zinc-500 dark:text-zinc-400">Net Total</span>
                                <span class="text-xl font-bold text-zinc-900 dark:text-white">₹ 1,200</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-3">
                    <div class="bg-white dark:bg-zinc-900 rounded-2xl shadow-soft border border-zinc-100 dark:border-zinc-800 p-6 lg:p-8 transition-colors duration-300">
                        <h3 class="text-lg font-bold text-zinc-900 dark:text-white mb-6 flex items-center gap-2">
                            <i class="ri-receipt-line text-brand-600 dark:text-brand-400"></i> Price Breakdown
                        </h3>
                        <div class="space-y-4">
                            <div class="flex justify-between text-sm">
                                <span class="text-zinc-500 dark:text-zinc-400">Total MRP</span>
                                <span class="font-medium text-zinc-800 dark:text-zinc-200">₹ 1,920</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-zinc-500 dark:text-zinc-400">Discount on MRP</span>
                                <span class="font-medium text-green-600 dark:text-green-400">− ₹ 0</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-zinc-500 dark:text-zinc-400">Platform Fee</span>
                                <span class="font-medium text-zinc-800 dark:text-zinc-200">₹ 20</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-zinc-500 dark:text-zinc-400">Shipping Fee</span>
                                <span class="font-semibold text-green-600 dark:text-green-400">FREE</span>
                            </div>
                        </div>
                        <div class="border-t border-zinc-200 dark:border-zinc-700 my-6"></div>
                        <div class="flex justify-between items-center mb-8">
                            <span class="text-lg font-bold text-zinc-900 dark:text-white">Total Amount</span>
                            <span class="text-2xl font-bold text-green-600 dark:text-green-400">₹ 1,940</span>
                        </div>
                        <button type="button" class="w-full py-3.5 rounded-xl bg-gradient-to-r from-brand-500 to-brand-700 text-white font-semibold shadow-md shadow-brand-500/25 hover:shadow-lg hover:-translate-y-0.5 transition-all flex items-center justify-center gap-2">
                            <i class="ri-secure-payment-line"></i>
                            Proceed to Checkout
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('./partials/footer') %>
