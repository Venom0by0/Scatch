<%- include('./partials/header') %>

    <% if(success && success.length > 0){ %>
        <div class="fixed top-20 left-1/2 -translate-x-1/2 z-50 flex items-center gap-2 px-5 py-3 rounded-xl bg-green-500 text-white shadow-lg shadow-green-500/25">
            <i class="ri-checkbox-circle-line text-lg"></i>
            <span class="text-sm font-medium"><%= success[0] %></span>
        </div>
    <% } %>

    <main class="min-h-screen pt-24 pb-12 px-4 sm:px-6 lg:px-10 bg-gradient-to-br from-zinc-50 to-brand-50/30 dark:from-zinc-950 dark:to-zinc-900 transition-colors duration-300">
        <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-8">
            <aside class="lg:w-56 shrink-0">
                <div class="bg-white dark:bg-zinc-900 rounded-2xl shadow-soft border border-zinc-100 dark:border-zinc-800 p-5 sticky top-24 transition-colors duration-300">
                    <p class="text-xs font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500 mb-4">Admin Panel</p>
                    <nav class="flex flex-col gap-1">
                        <a class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium text-zinc-600 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-colors" href="/shop">
                            <i class="ri-store-2-line"></i> View Shop
                        </a>
                        <a class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium bg-brand-50 dark:bg-brand-500/20 text-brand-700 dark:text-brand-300" href="/owners/admin">
                            <i class="ri-add-box-line"></i> Create Product
                        </a>
                    </nav>
                </div>
            </aside>

            <div class="flex-1">
                <div class="bg-white dark:bg-zinc-900 rounded-2xl shadow-card border border-zinc-100 dark:border-zinc-800 p-6 lg:p-10 transition-colors duration-300">
                    <div class="flex items-center gap-3 mb-8">
                        <span class="w-12 h-12 rounded-xl bg-brand-100 dark:bg-brand-500/20 flex items-center justify-center text-brand-600 dark:text-brand-400">
                            <i class="ri-gift-2-line text-2xl"></i>
                        </span>
                        <div>
                            <h2 class="text-2xl font-bold text-zinc-900 dark:text-white">Create New Product</h2>
                            <p class="text-sm text-zinc-500 dark:text-zinc-400">Add a new item to your shop collection</p>
                        </div>
                    </div>

                    <form autocomplete="off" action="/products/create" method="post" enctype="multipart/form-data" class="space-y-8">
                        <div>
                            <h3 class="text-sm font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500 mb-4">Product Details</h3>
                            <div class="mb-5">
                                <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-2">Product Image</label>
                                <label class="flex flex-col items-center justify-center w-full h-36 border-2 border-dashed border-zinc-200 dark:border-zinc-700 rounded-xl bg-zinc-50 dark:bg-zinc-800/50 hover:bg-zinc-100/80 dark:hover:bg-zinc-800 hover:border-brand-300 dark:hover:border-brand-500 cursor-pointer transition-colors">
                                    <i class="ri-image-add-line text-3xl text-zinc-400 dark:text-zinc-500 mb-2"></i>
                                    <span class="text-sm text-zinc-500 dark:text-zinc-400">Click to upload image</span>
                                    <input name="image" type="file" class="hidden" accept="image/*">
                                </label>
                            </div>
                            <div class="grid sm:grid-cols-2 gap-4">
                                <input name="name" type="text" placeholder="Product Name"
                                    class="w-full px-4 py-3 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-xl text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 dark:placeholder:text-zinc-500 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all">
                                <input name="price" type="text" placeholder="Product Price (₹)"
                                    class="w-full px-4 py-3 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-xl text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 dark:placeholder:text-zinc-500 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all">
                                <input name="discount" type="text" placeholder="Discount (%)"
                                    class="w-full px-4 py-3 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-xl text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 dark:placeholder:text-zinc-500 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all sm:col-span-2">
                            </div>
                        </div>

                        <div>
                            <h3 class="text-sm font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500 mb-2">Panel Colors</h3>
                            <p class="text-xs text-zinc-400 dark:text-zinc-500 mb-4">Use Tailwind color names, e.g. <code class="bg-zinc-100 dark:bg-zinc-800 px-1.5 py-0.5 rounded text-zinc-700 dark:text-zinc-300">yellow-500</code>, <code class="bg-zinc-100 dark:bg-zinc-800 px-1.5 py-0.5 rounded text-zinc-700 dark:text-zinc-300">red-500</code></p>
                            <div class="grid sm:grid-cols-3 gap-4">
                                <input name="bgcolor" type="text" placeholder="Background Color"
                                    class="w-full px-4 py-3 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-xl text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 dark:placeholder:text-zinc-500 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all">
                                <input name="panelcolor" type="text" placeholder="Panel Color"
                                    class="w-full px-4 py-3 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-xl text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 dark:placeholder:text-zinc-500 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all">
                                <input name="textcolor" type="text" placeholder="Text Color"
                                    class="w-full px-4 py-3 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-xl text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 dark:placeholder:text-zinc-500 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all">
                            </div>
                        </div>

                        <button type="submit" class="px-8 py-3.5 rounded-xl bg-gradient-to-r from-brand-500 to-brand-700 text-white font-semibold shadow-md shadow-brand-500/25 hover:shadow-lg hover:-translate-y-0.5 transition-all flex items-center gap-2">
                            <i class="ri-add-line"></i>
                            Create New Product
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <%- include('./partials/footer') %>
