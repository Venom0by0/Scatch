<%- include('./partials/header') %>

    <% if(error && error.length > 0){ %>
        <div class="fixed top-20 left-1/2 -translate-x-1/2 z-50 flex items-center gap-2 px-5 py-3 rounded-xl bg-red-500 text-white shadow-lg shadow-red-500/25 animate-pulse">
            <i class="ri-error-warning-line text-lg"></i>
            <span class="text-sm font-medium"><%= error[0] %></span>
        </div>
    <% } %>

    <main class="min-h-screen pt-24 pb-12 px-4 sm:px-6 lg:px-10 bg-gradient-to-br from-zinc-50 via-white to-brand-50 dark:from-zinc-950 dark:via-zinc-900 dark:to-zinc-950 transition-colors duration-300">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-12 lg:mb-16">
                <p class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-100 dark:bg-brand-500/20 text-brand-700 dark:text-brand-300 text-xs font-semibold uppercase tracking-wider mb-4">
                    <i class="ri-sparkling-2-line"></i> Welcome
                </p>
                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-zinc-900 dark:text-white mb-4">
                    Discover style with <span class="bg-gradient-to-r from-brand-500 to-brand-700 bg-clip-text text-transparent">Scatch</span>
                </h1>
                <p class="text-zinc-500 dark:text-zinc-400 text-lg max-w-xl mx-auto">Create an account or sign in to explore our curated collection of premium products.</p>
            </div>

            <div class="grid lg:grid-cols-2 gap-8 lg:gap-10">
                <div class="bg-white dark:bg-zinc-900 rounded-2xl shadow-card border border-zinc-100 dark:border-zinc-800 p-8 lg:p-10 hover:shadow-soft transition-all duration-300">
                    <div class="flex items-center gap-3 mb-6">
                        <span class="w-12 h-12 rounded-xl bg-brand-100 dark:bg-brand-500/20 flex items-center justify-center text-brand-600 dark:text-brand-400">
                            <i class="ri-user-add-line text-2xl"></i>
                        </span>
                        <div>
                            <h2 class="text-2xl font-bold text-zinc-900 dark:text-white">Create account</h2>
                            <p class="text-sm text-zinc-500 dark:text-zinc-400">Join Scatch today — it's free</p>
                        </div>
                    </div>
                    <form autocomplete="off" action="/users/register" method="post" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1.5">Full Name</label>
                            <input class="w-full px-4 py-3 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-xl text-zinc-900 dark:text-zinc-100 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all placeholder:text-zinc-400 dark:placeholder:text-zinc-500"
                                type="text" placeholder="John Doe" name="fullname">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1.5">Email</label>
                            <input class="w-full px-4 py-3 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-xl text-zinc-900 dark:text-zinc-100 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all placeholder:text-zinc-400 dark:placeholder:text-zinc-500"
                                type="email" placeholder="you@example.com" name="email">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1.5">Password</label>
                            <input class="w-full px-4 py-3 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-xl text-zinc-900 dark:text-zinc-100 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all placeholder:text-zinc-400 dark:placeholder:text-zinc-500"
                                type="password" placeholder="••••••••" name="password">
                        </div>
                        <button type="submit" class="w-full mt-2 px-6 py-3.5 rounded-xl bg-gradient-to-r from-brand-500 to-brand-700 text-white font-semibold shadow-md shadow-brand-500/25 hover:shadow-lg hover:-translate-y-0.5 transition-all">
                            Create My Account
                        </button>
                    </form>
                </div>

                <div class="bg-white dark:bg-zinc-900 rounded-2xl shadow-card border border-zinc-100 dark:border-zinc-800 p-8 lg:p-10 hover:shadow-soft transition-all duration-300">
                    <div class="flex items-center gap-3 mb-6">
                        <span class="w-12 h-12 rounded-xl bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-600 dark:text-zinc-300">
                            <i class="ri-login-box-line text-2xl"></i>
                        </span>
                        <div>
                            <h2 class="text-2xl font-bold text-zinc-900 dark:text-white">Sign in</h2>
                            <p class="text-sm text-zinc-500 dark:text-zinc-400">Welcome back — we missed you</p>
                        </div>
                    </div>
                    <form autocomplete="off" action="/users/login" method="post" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1.5">Email</label>
                            <input class="w-full px-4 py-3 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-xl text-zinc-900 dark:text-zinc-100 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all placeholder:text-zinc-400 dark:placeholder:text-zinc-500"
                                type="email" placeholder="you@example.com" name="email">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1.5">Password</label>
                            <input class="w-full px-4 py-3 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-xl text-zinc-900 dark:text-zinc-100 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all placeholder:text-zinc-400 dark:placeholder:text-zinc-500"
                                type="password" placeholder="••••••••" name="password">
                        </div>
                        <button type="submit" class="w-full mt-2 px-6 py-3.5 rounded-xl bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 font-semibold shadow-md hover:bg-zinc-800 dark:hover:bg-zinc-100 hover:-translate-y-0.5 transition-all">
                            Login
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <%- include('./partials/footer') %>
